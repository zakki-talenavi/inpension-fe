{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:test": "NUXT_PUBLIC_API_BASE_URL=http://localhost:3000/api nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "oxlint --type-aware && eslint .",
    "lint:oxlint": "oxlint --type-aware",
    "lint:eslint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project nuxt",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:auth": "playwright test test/e2e/auth",
    "test:e2e:products": "playwright test test/e2e/products",
    "test:e2e:checkout": "playwright test test/e2e/checkout"
  },
  "dependencies": {
    "@nuxt/eslint": "1.10.0",
    "@nuxt/image": "1.11.0",
    "@nuxt/scripts": "0.13.0",
    "@nuxt/ui": "4.1.0",
    "@pinia/nuxt": "^0.11.2",
    "@primeuix/themes": "^2.0.3",
    "@primevue/nuxt-module": "^4.5.4",
    "@primevue/themes": "^4.5.4",
    "@tailwindcss/vite": "^4.2.1",
    "@unhead/vue": "^2.0.3",
    "axios": "^1.13.5",
    "eslint": "^9.0.0",
    "nuxt": "^4.2.0",
    "pinia": "^3.0.3",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.3",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@anatine/zod-mock": "^3.13.4",
    "@nuxt/test-utils": "^3.23.0",
    "@playwright/test": "^1.58.1",
    "@vue/test-utils": "^2.4.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-nuxt-layers": "^0.2.0",
    "eslint-plugin-oxlint": "^1.25.0",
    "fast-check": "^3.23.1",
    "happy-dom": "^20.5.0",
    "oxlint": "^1.25.0",
    "oxlint-tsgolint": "^0.4.0",
    "vitest": "^4.0.18"
  }
}